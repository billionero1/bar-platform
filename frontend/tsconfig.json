{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    "allowJs": false,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "types": ["vite/client", "react", "react-dom"]
  },
  "include": ["src", "src2/features/workspace/Footer.tsx", "src2/features/workspace/Header.tsx", "src2/features/auth/components/PhoneInput.tsx", "src2/features/auth/hooks/ResendTimer.ts", "src2/features/auth/hooks/useLogin.ts", "src2/features/auth/hooks/useRecovery.ts", "src2/features/auth/hooks/useRegister.ts", "src2/layouts/MobileLayout/MobileLayout.tsx"]
}

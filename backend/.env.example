PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=appdb
PGUSER=app
PGPASSWORD=CHANGE_ME_DB_PASSWORD

# ADMIN REMINDER:
# Ротация секретов НЕ нужна каждый день.
# Используй только при первом деплое/плановой смене:
# npm --prefix backend run secrets:rotate -- --env .env --in-place

NODE_ENV=development
HOST=127.0.0.1
PORT=3001
FORCE_HTTPS=0

JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
PHONE_VERIFICATION_TTL_MINUTES=60

FRONTEND_ORIGIN=
COOKIE_NAME=sid
CSRF_SECRET=CHANGE_ME_CSRF_SECRET
ALLOW_DESTRUCTIVE_MIGRATIONS=0

# OTP delivery
# Provider order: telegram,webhook
OTP_PROVIDER_ORDER=telegram,webhook
OTP_TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
# Fallback target chats (optional). Для прод-регистрации лучше использовать связку через отдельного бота:
# OTP_TELEGRAM_BOT_USERNAME + OTP_TELEGRAM_BIND_SECRET
OTP_TELEGRAM_CHAT_IDS=
OTP_TELEGRAM_API_BASE=https://api.telegram.org
OTP_TELEGRAM_BOT_USERNAME=CHANGE_ME_AUTH_BOT_USERNAME_WITHOUT_@
OTP_TELEGRAM_BIND_SECRET=CHANGE_ME_TELEGRAM_BIND_SECRET_MIN_16_CHARS
OTP_TELEGRAM_BIND_TOKEN_TTL_MINUTES=20
OTP_WEBHOOK_URL=https://otp.example.com/hook
OTP_WEBHOOK_TOKEN=CHANGE_ME_WEBHOOK_BEARER_TOKEN

# Private media storage
STORAGE_ROOT=./storage

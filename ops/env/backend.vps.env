# =========================
# BAR PLATFORM BACKEND ENV
# =========================
# Скопируй в /opt/bar-platform/app/backend/.env и заполни PASTE_... значения.

# PostgreSQL (ОТДЕЛЬНЫЙ инстанс для бара, не тот что у vpn-бота)
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=bar_platform
PGUSER=bar_platform_user
PGPASSWORD=PASTE_DB_PASSWORD_HERE

# Runtime
NODE_ENV=production
HOST=127.0.0.1
PORT=3001
FORCE_HTTPS=1

# Auth / sessions
JWT_SECRET=PASTE_LONG_RANDOM_JWT_SECRET_HERE
ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
PHONE_VERIFICATION_TTL_MINUTES=60

# Домен фронта (для текущего кейса: https://bar-calc.ru)
FRONTEND_ORIGIN=https://bar-calc.ru,https://www.bar-calc.ru
COOKIE_NAME=sid
CSRF_SECRET=PASTE_LONG_RANDOM_CSRF_SECRET_HERE

# Безопасность миграций
ALLOW_DESTRUCTIVE_MIGRATIONS=0

# OTP (Telegram)
OTP_PROVIDER_ORDER=telegram
OTP_TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
# Для регистрации через отдельного auth-бота:
OTP_TELEGRAM_BOT_USERNAME=PASTE_AUTH_BOT_USERNAME_WITHOUT_@
OTP_TELEGRAM_BIND_SECRET=PASTE_LONG_RANDOM_BIND_SECRET_HERE
OTP_TELEGRAM_BIND_TOKEN_TTL_MINUTES=20
# Fallback-канал (опционально, обычно оставить пустым)
OTP_TELEGRAM_CHAT_IDS=
OTP_TELEGRAM_API_BASE=https://api.telegram.org
# Webhook URL формируется так:
# https://bar-calc.ru/v1/auth/telegram/webhook/${OTP_TELEGRAM_BIND_SECRET}

# OTP webhook (не нужен при Telegram-only, оставить пустым)
OTP_WEBHOOK_URL=
OTP_WEBHOOK_TOKEN=

# Приватное хранилище фото
STORAGE_ROOT=/opt/bar-platform/backend/storage
